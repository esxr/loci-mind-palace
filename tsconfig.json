{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@web/*": ["src/web/*"]
    }
  },
  "include": ["src/web", "src/shared"],
  "exclude": ["node_modules", "dist", "dist-plugin", "supabase", "src/functions"]
}
