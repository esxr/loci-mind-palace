  "concept_graph": {
    "concepts": [
      {
        "id": "cell_structure",
        "name": "Cell Structure",
        "description": "The cell is the fundamental unit of life. Eukaryotic cells contain membrane-bound organelles that compartmentalize functions including energy production, protein synthesis, and genetic storage.",
        "importance": 9,
        "cluster_label": "cell_biology",
        "source_notes": ["cell-structure"],
        "spatial_hint": "central",
        "display_size": "large"
      },
      {
        "id": "dna",
        "name": "DNA",
        "description": "Deoxyribonucleic acid is the double-helical molecule that stores and transmits hereditary information through complementary base pairing, encoding genes that direct protein synthesis and cellular function.",
        "importance": 10,
        "cluster_label": "genetics",
        "source_notes": ["dna"],
        "spatial_hint": "central",
        "display_size": "large"
      },
      {
        "id": "mitochondria",
        "name": "Mitochondria",
        "description": "Double-membrane organelles that generate most of the cell's ATP through oxidative phosphorylation. They possess their own circular DNA, supporting the endosymbiotic theory of their bacterial origin.",
        "importance": 8,
        "cluster_label": "cell_biology",
        "source_notes": ["mitochondria"],
        "spatial_hint": "standard",
        "display_size": "medium"
      },
      {
        "id": "proteins",
        "name": "Proteins",
        "description": "Large macromolecules composed of amino acid chains that serve as enzymes, structural components, transport carriers, and signaling molecules. Their function depends on precise three-dimensional folding.",
        "importance": 8,
        "cluster_label": "molecular_biology",
        "source_notes": ["proteins"],
        "spatial_hint": "gateway",
        "display_size": "medium"
      },
      {
        "id": "evolution",
        "name": "Evolution",
        "description": "The change in heritable characteristics within populations over successive generations, driven by natural selection, genetic drift, gene flow, and mutation. It is the unifying theory of biology.",
        "importance": 9,
        "cluster_label": "evolution",
        "source_notes": ["evolution"],
        "spatial_hint": "central",
        "display_size": "large"
      },
      {
        "id": "photosynthesis",
        "name": "Photosynthesis",
        "description": "The biological process by which plants, algae, and cyanobacteria convert light energy into chemical energy stored in glucose, releasing oxygen as a byproduct. It is the energetic foundation of nearly all ecosystems.",
        "importance": 7,
        "cluster_label": "physiology",
        "source_notes": ["photosynthesis"],
        "spatial_hint": "standard",
        "display_size": "medium"
      },
      {
        "id": "mutations",
        "name": "Mutations",
        "description": "Heritable changes in the DNA nucleotide sequence that serve as the ultimate source of all genetic variation. They range from single-nucleotide point mutations to large chromosomal rearrangements.",
        "importance": 6,
        "cluster_label": "genetics",
        "source_notes": ["mutations"],
        "spatial_hint": "peripheral",
        "display_size": "small"
      },
      {
        "id": "enzymes",
        "name": "Enzymes",
        "description": "Biological catalysts, predominantly proteins, that accelerate chemical reactions by lowering activation energy. They are central to virtually every aspect of metabolism.",
        "importance": 7,
        "cluster_label": "molecular_biology",
        "source_notes": ["enzymes"],
        "spatial_hint": "standard",
        "display_size": "medium"
      },
      {
        "id": "cell_membrane",
        "name": "Cell Membrane",
        "description": "The selectively permeable phospholipid bilayer enclosing every living cell, regulating molecular transport, cell signaling, and cell-cell recognition through embedded proteins and cholesterol.",
        "importance": 7,
        "cluster_label": "cell_biology",
        "source_notes": ["cell-membrane"],
        "spatial_hint": "gateway",
        "display_size": "medium"
      },
      {
        "id": "natural_selection",
        "name": "Natural Selection",
        "description": "The mechanism of evolution by which organisms with heritable traits conferring survival or reproductive advantage leave more offspring, increasing the frequency of those traits in subsequent generations.",
        "importance": 8,
        "cluster_label": "evolution",
        "source_notes": ["natural-selection"],
        "spatial_hint": "standard",
        "display_size": "medium"
      }
    ],
