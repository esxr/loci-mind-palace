  "npcs": [
    {
      "id": "photosynthesis_npc",
      "concept_id": "photosynthesis",
      "name": "Photosynthesis",
      "position": { "x": 8, "y": 0, "z": 6 },
      "facing": 3.14,
      "voxel_model": {
        "style": "forest_sage",
        "palette": { "body": "#5b8c3e", "head": "#8bc34a", "accent": "#ffeb3b" },
        "height_blocks": 3
      },
      "dialogue_context": {
        "concept_description": "The biological process by which plants, algae, and cyanobacteria convert light energy into chemical energy stored in glucose, releasing oxygen as a byproduct. It is the energetic foundation of nearly all ecosystems.",
        "neighbor_ids": ["enzymes", "mitochondria"]
      }
    },
    {
      "id": "cell_structure_npc",
      "concept_id": "cell_structure",
      "name": "Cell Structure",
      "position": { "x": 36, "y": 0, "z": 8 },
      "facing": 3.14,
      "voxel_model": {
        "style": "forest_sage",
        "palette": { "body": "#5b8c3e", "head": "#8bc34a", "accent": "#ffeb3b" },
        "height_blocks": 3
      },
      "dialogue_context": {
        "concept_description": "The cell is the fundamental unit of life. Eukaryotic cells contain membrane-bound organelles that compartmentalize functions including energy production, protein synthesis, and genetic storage.",
        "neighbor_ids": ["mitochondria", "cell_membrane", "dna"]
      }
    },
    {
      "id": "mitochondria_npc",
      "concept_id": "mitochondria",
      "name": "Mitochondria",
      "position": { "x": 8, "y": 0, "z": 31 },
      "facing": 3.14,
      "voxel_model": {
        "style": "forest_sage",
        "palette": { "body": "#5b8c3e", "head": "#8bc34a", "accent": "#ffeb3b" },
        "height_blocks": 3
      },
      "dialogue_context": {
        "concept_description": "Double-membrane organelles that generate most of the cell's ATP through oxidative phosphorylation. They possess their own circular DNA, supporting the endosymbiotic theory of their bacterial origin.",
        "neighbor_ids": ["cell_structure", "photosynthesis"]
      }
    },
    {
      "id": "dna_npc",
      "concept_id": "dna",
      "name": "DNA",
      "position": { "x": 51, "y": 0, "z": 33 },
      "facing": 3.14,
      "voxel_model": {
        "style": "forest_sage",
        "palette": { "body": "#5b8c3e", "head": "#8bc34a", "accent": "#ffeb3b" },
        "height_blocks": 3
      },
      "dialogue_context": {
        "concept_description": "Deoxyribonucleic acid is the double-helical molecule that stores and transmits hereditary information through complementary base pairing, encoding genes that direct protein synthesis and cellular function.",
        "neighbor_ids": ["mutations", "proteins", "cell_structure"]
      }
    },
    {
      "id": "cell_membrane_npc",
      "concept_id": "cell_membrane",
      "name": "Cell Membrane",
      "position": { "x": 2, "y": 0, "z": 54 },
      "facing": 3.14,
      "voxel_model": {
        "style": "forest_sage",
        "palette": { "body": "#5b8c3e", "head": "#8bc34a", "accent": "#ffeb3b" },
        "height_blocks": 3
      },
      "dialogue_context": {
        "concept_description": "The selectively permeable phospholipid bilayer enclosing every living cell, regulating molecular transport, cell signaling, and cell-cell recognition through embedded proteins and cholesterol.",
        "neighbor_ids": ["cell_structure", "proteins"]
      }
    },
    {
      "id": "enzymes_npc",
      "concept_id": "enzymes",
      "name": "Enzymes",
      "position": { "x": 24, "y": 0, "z": 56 },
      "facing": 3.14,
      "voxel_model": {
        "style": "forest_sage",
        "palette": { "body": "#5b8c3e", "head": "#8bc34a", "accent": "#ffeb3b" },
        "height_blocks": 3
      },
      "dialogue_context": {
        "concept_description": "Biological catalysts, predominantly proteins, that accelerate chemical reactions by lowering activation energy. They are central to virtually every aspect of metabolism.",
        "neighbor_ids": ["proteins", "photosynthesis"]
      }
    },
    {
      "id": "mutations_npc",
      "concept_id": "mutations",
      "name": "Mutations",
      "position": { "x": 52, "y": 0, "z": 54 },
      "facing": 3.14,
      "voxel_model": {
        "style": "forest_sage",
        "palette": { "body": "#5b8c3e", "head": "#8bc34a", "accent": "#ffeb3b" },
        "height_blocks": 3
      },
      "dialogue_context": {
        "concept_description": "Heritable changes in the DNA nucleotide sequence that serve as the ultimate source of all genetic variation. They range from single-nucleotide point mutations to large chromosomal rearrangements.",
        "neighbor_ids": ["dna", "evolution", "natural_selection"]
      }
    },
    {
      "id": "proteins_npc",
      "concept_id": "proteins",
      "name": "Proteins",
      "position": { "x": 8, "y": 0, "z": 81 },
      "facing": 3.14,
      "voxel_model": {
        "style": "forest_sage",
        "palette": { "body": "#5b8c3e", "head": "#8bc34a", "accent": "#ffeb3b" },
        "height_blocks": 3
      },
      "dialogue_context": {
        "concept_description": "Large macromolecules composed of amino acid chains that serve as enzymes, structural components, transport carriers, and signaling molecules. Their function depends on precise three-dimensional folding.",
        "neighbor_ids": ["enzymes", "dna", "cell_membrane"]
      }
    },
    {
      "id": "evolution_npc",
      "concept_id": "evolution",
      "name": "Evolution",
      "position": { "x": 31, "y": 0, "z": 83 },
      "facing": 3.14,
      "voxel_model": {
        "style": "forest_sage",
        "palette": { "body": "#5b8c3e", "head": "#8bc34a", "accent": "#ffeb3b" },
        "height_blocks": 3
      },
      "dialogue_context": {
        "concept_description": "The change in heritable characteristics within populations over successive generations, driven by natural selection, genetic drift, gene flow, and mutation. It is the unifying theory of biology.",
        "neighbor_ids": ["natural_selection", "mutations"]
      }
    },
    {
      "id": "natural_selection_npc",
      "concept_id": "natural_selection",
      "name": "Natural Selection",
      "position": { "x": 54, "y": 0, "z": 81 },
      "facing": 3.14,
      "voxel_model": {
        "style": "forest_sage",
        "palette": { "body": "#5b8c3e", "head": "#8bc34a", "accent": "#ffeb3b" },
        "height_blocks": 3
      },
      "dialogue_context": {
        "concept_description": "The mechanism of evolution by which organisms with heritable traits conferring survival or reproductive advantage leave more offspring, increasing the frequency of those traits in subsequent generations.",
        "neighbor_ids": ["evolution", "mutations"]
      }
    }
  ],

